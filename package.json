{
  "name": "hammerjs",
  "version": "3.0.0-experimental",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "tsc --emitDeclarationOnly && vite build",
    "build:watch": "tsc --emitDeclarationOnly --watch & vite build --watch",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "gts lint",
    "lint:fix": "gts fix",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "posttest": "npm run lint"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "gts": "^5.3.1",
    "jsdom": "^27.2.0",
    "prettier": "^3.3.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.9"
  },
  "exports": {
    ".": {
      "types": "./dist/types/hammer.d.ts",
      "import": "./dist/hammer.es.js",
      "require": "./dist/hammer.umd.cjs"
    }
  },
  "types": "./dist/types/hammer.d.ts",
  "files": [
    "dist"
  ]
}
